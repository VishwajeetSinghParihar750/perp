// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}



enum ORDER_SIDE {
  BUY
  SELL
}

enum MARKET_SYMBOL {
  ETHUSD
  BTCUSD
  SOLUSD
}

enum ORDER_TYPE {
  MARKET
  LIMIT
}
enum MARGIN_TYPE {
  ISOLATED 
  CROSS
}
enum ORDER_STATUS {
  OPEN
  FILLED
  PARTIALLY_FILLED
  CANCELLED
}

model Market {
  id String @id @default(uuid())
  symbol MARKET_SYMBOL @unique

  //
  orders Order[]
  fills Fill[]
}

model User {

  id String @id @default(uuid())
  username String @unique
  password String 
  createdAt DateTime @default(now())

  //
  orders Order[]
  longFills Fill[] @relation(name: "longUser")
  shortFills Fill[] @relation(name: "shortUser")
  
}

model Order {
  id String @id @default(uuid())
  userId String 
  side ORDER_SIDE
  symbol MARKET_SYMBOL
  margin Decimal @db.Decimal(18,0)
  price Decimal @db.Decimal(18,0)
  filledQuantity Decimal @db.Decimal(18,0)
  quantity Decimal @db.Decimal(18,0)
  status ORDER_STATUS

  type ORDER_TYPE
  marginType MARGIN_TYPE
  //
  user User @relation(fields: [userId],references: [id])
  longFills Fill[] @relation(name : "longOrder")
  shortFills Fill[] @relation(name : "shortOrder")
  market Market @relation(fields: [symbol], references: [symbol])
}

model Fill {
  id String @id @default(ulid())
  symbol MARKET_SYMBOL
  quantity Decimal @db.Decimal(18,0)
  price Decimal @db.Decimal(18,0)
  bidPrice Decimal @db.Decimal(18,0)

  longUserId String
  shortUserId String

  longOrderId String
  shortOrderId String

  // 
  longUser User @relation(name: "longUser", fields: [longUserId], references: [id])
  shortUser User @relation(name: "shortUser", fields: [shortUserId], references: [id])
  
  longOrder Order @relation(name : "longOrder"  ,fields: [longOrderId], references: [id])
  shortOrder Order @relation(name : "shortOrder" ,fields: [shortOrderId], references: [id])

  market Market @relation(fields: [symbol], references: [symbol])

}